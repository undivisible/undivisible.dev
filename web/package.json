{
  "name": "@workspace/undivisible",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "sync:readme": "bun run scripts/sync-readme-projects.ts",
    "sync:now": "bun run scripts/sync-now-markdown.ts",
    "sync:resume": "bun run scripts/sync-resume.ts",
    "sync:lastfm": "bun run scripts/sync-lastfm-snapshot.ts",
    "sync:agent": "bun run scripts/sync-agent-public.ts",
    "prebuild": "bun run sync:readme && bun run sync:now && bun run sync:resume && bun run sync:lastfm && bun run sync:agent",
    "build": "next build",
    "format": "bunx prettier --check .",
    "lint": "bun run typecheck",
    "serve": "next start",
    "test": "bun test",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "^16.2.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0"
  },
  "dependencies": {
    "motion": "^12.38.0"
  }
}